@model ServiceFlow.Web.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-controller="User" asp-action="Index" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Volver a usuarios
        </a>
        <h2 class="fw-bold mt-1" style="color: #25262a;">Editar Usuario</h2>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Edit" asp-controller="User" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="FirstName" class="form-label fw-semibold"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="PaternalSurname" class="form-label fw-semibold"></label>
                        <input asp-for="PaternalSurname" class="form-control" />
                        <span asp-validation-for="PaternalSurname" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="MaternalSurname" class="form-label fw-semibold"></label>
                        <input asp-for="MaternalSurname" class="form-control" />
                        <span asp-validation-for="MaternalSurname" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select" asp-items="ViewBag.Roles">
                            <option value="">-- Selecciona un rol --</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2">
                    <button type="submit" class="btn px-4" style="background-color: #25262a; color: white;">
                        <i class="bi bi-floppy me-1"></i>Guardar Cambios
                    </button>
                    <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                    <button type="button" class="btn btn-outline-danger px-4 ms-auto"
                            data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash me-1"></i>Eliminar usuario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL ELIMINAR -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>Eliminar Usuario
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">
                    Esta acción es <strong>irreversible</strong>. Se eliminará permanentemente el usuario
                    <strong>@Model.FirstName @Model.PaternalSurname</strong>.
                </p>
                <hr />
                <p class="small fw-semibold mb-2">
                    Escribe <span class="text-danger fw-bold">CONFIRMAR</span> para continuar:
                </p>
                <input type="text" id="confirmInput" class="form-control" placeholder="CONFIRMAR" autocomplete="off" />
                <p id="confirmError" class="text-danger small mt-1 d-none">Debes escribir CONFIRMAR exactamente.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form asp-controller="User" asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" id="deleteBtn" class="btn btn-danger" disabled>
                        <i class="bi bi-trash me-1"></i>Eliminar definitivamente
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('confirmInput').addEventListener('input', function () {
        const val = this.value;
        const btn = document.getElementById('deleteBtn');
        const error = document.getElementById('confirmError');
        if (val === 'CONFIRMAR') {
            btn.disabled = false;
            error.classList.add('d-none');
        } else {
            btn.disabled = true;
            if (val.length > 0) error.classList.remove('d-none');
            else error.classList.add('d-none');
        }
    });
</script>
