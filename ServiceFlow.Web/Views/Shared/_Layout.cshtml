<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ServiceFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ServiceFlow.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        body {
            display: flex;
            min-height: 100vh;
            background-color: #f5f5f5;
        }

        .sidebar {
            width: 72px;
            min-height: 100vh;
            background-color: #131317;
            border-right: 1px solid #1e1e24;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            align-items: center;
        }

        .sidebar-logo {
            padding: 20px 0;
            border-bottom: 1px solid #1e1e24;
            width: 100%;
            display: flex;
            justify-content: center;
        }

        .sidebar-nav {
            flex-grow: 1;
            padding: 12px 0;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .sidebar-nav .nav-link {
                color: #6c757d;
                border-radius: 8px;
                padding: 10px 0;
                margin-bottom: 4px;
                width: 52px;
                font-size: 0.6rem;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 4px;
                text-decoration: none;
                transition: background-color 0.2s ease, color 0.2s ease;
            }

                .sidebar-nav .nav-link i {
                    font-size: 1.1rem;
                }

                .sidebar-nav .nav-link:hover {
                    background-color: #1e1e24;
                    color: #ffffff;
                }

                .sidebar-nav .nav-link.active {
                    background-color: #2a2a32;
                    color: #ffffff;
                    font-weight: 600;
                }

        .sidebar-footer {
            padding: 12px 0;
            border-top: 1px solid #1e1e24;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

            .sidebar-footer .user-info {
                font-size: 0.6rem;
                color: #6c757d;
                margin-bottom: 4px;
                text-align: center;
                padding: 4px 0;
            }

            .sidebar-footer .btn-logout {
                width: 52px;
                color: #dc3545;
                border-radius: 8px;
                padding: 10px 0;
                font-size: 0.6rem;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 4px;
                background: none;
                border: none;
                cursor: pointer;
                transition: background-color 0.2s ease;
            }

                .sidebar-footer .btn-logout i {
                    font-size: 1.1rem;
                }

                .sidebar-footer .btn-logout:hover {
                    background-color: #1e1e24;
                }

        .main-wrapper {
            margin-left: 72px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            padding: 32px;
        }

        .footer-avatar {
            border-radius: 50%;
            border: 2px solid #e9ecef;
            transition: border-color 0.2s ease;
        }

        .footer-dev:hover .footer-avatar {
            border-color: #25262a;
        }

        .footer-contribute {
            font-size: 0.8rem;
            color: #6c757d;
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: color 0.2s ease;
        }

            .footer-contribute:hover {
                color: #25262a;
            }
    </style>
</head>
<body>

    @if (User.Identity!.IsAuthenticated)
    {
        <aside class="sidebar">
            <!-- LOGO -->
            <div class="sidebar-logo">
                <a asp-controller="Home" asp-action="Index">
                    <!-- tenia height="32" el img src de icon-->
                    <img src="~/images/ICON.svg" alt="ServiceFlow" />
                </a>
            </div>

            <!-- NAV LINKS -->
            <nav class="sidebar-nav">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>

                @if (User.IsInRole("User"))
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Request" ? "active" : "")"
                       asp-controller="Request" asp-action="Index">
                        <i class="bi bi-ticket"></i>
                        <span>Solicitudes</span>
                    </a>
                }
                @if (User.IsInRole("Agent"))
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Request" ? "active" : "")"
                       asp-controller="Request" asp-action="MyWork">
                        <i class="bi bi-clipboard-check"></i>
                        <span>Mi Trabajo</span>
                    </a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Request" ? "active" : "")"
                       asp-controller="Request" asp-action="Index">
                        <i class="bi bi-ticket"></i>
                        <span>Solicitudes</span>
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
                       asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span>Usuarios</span>
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                       asp-controller="Category" asp-action="Index">
                        <i class="bi bi-tag"></i>
                        <span>Categorías</span>
                    </a>
                }
            </nav>

            <!-- FOOTER -->
            <div class="sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Salir</span>
                    </button>
                </form>
            </div>
        </aside>
    }

    <div class="main-wrapper">
        <div class="main-content">
            @RenderBody()
        </div>

        <footer class="border-top text-muted">
            <div class="px-4 py-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <small class="text-muted">Equipo de Desarrollo</small>
                    <a href="https://github.com/floreslog" target="_blank" class="footer-dev">
                        <img src="https://github.com/floreslog.png" width="28" height="28" class="footer-avatar" />
                    </a>
                    <a href="https://github.com/nicolasdluna01" target="_blank" class="footer-dev">
                        <img src="https://github.com/nicolasdluna01.png" width="28" height="28" class="footer-avatar" />
                    </a>
                </div>
                <a href="https://github.com/floreslog/serviceflow-sistema-de-solicitudes" target="_blank" class="footer-contribute">
                    <i class="bi bi-git me-1"></i> Contribuir
                </a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <div id="toast-success" style="
            position: fixed;
            bottom: 28px;
            right: 28px;
            background-color: #25262a;
            color: white;
            padding: 14px 20px;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 500;
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
            z-index: 9999;
            opacity: 1;
            transition: opacity 0.6s ease;
        ">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>

        <script>
            setTimeout(() => {
                const toast = document.getElementById('toast-success');
                if (toast) toast.style.opacity = '0';
                setTimeout(() => toast?.remove(), 600);
            }, 2500);
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <div id="toast-error" style="
            position: fixed;
            bottom: 28px;
            right: 28px;
            background-color: #dc3545;
            color: white;
            padding: 14px 20px;
            border-radius: 10px;
            font-size: 0.85rem;
            font-weight: 500;
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
            z-index: 9999;
            opacity: 1;
            transition: opacity 0.6s ease;
        ">
            <i class="bi bi-x-circle me-2"></i>@TempData["Error"]
        </div>

        <script>
            setTimeout(() => {
                const toast = document.getElementById('toast-error');
                if (toast) toast.style.opacity = '0';
                setTimeout(() => toast?.remove(), 600);
            }, 3500);
        </script>
    }


</body>
</html>