@model ServiceFlow.Web.ViewModels.RequestDetailViewModel
@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<style>
    .ticket-wrapper {
        max-width: 960px;
        margin: 0 auto;
    }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .ticket-back {
        font-size: 0.8rem;
        color: #9aa0a6;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 8px;
    }

        .ticket-back:hover {
            color: #25262a;
        }

    .ticket-id {
        font-size: 0.8rem;
        color: #9aa0a6;
        margin-bottom: 4px;
    }

    .ticket-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #25262a;
        margin: 0;
    }

    .ticket-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
        border: 1px solid #e9ecef;
    }

    .ticket-body {
        padding: 28px;
    }

    .ticket-section-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #9aa0a6;
        margin-bottom: 6px;
    }

    .ticket-section-value {
        font-size: 0.9rem;
        color: #25262a;
        font-weight: 500;
        margin: 0;
    }

    .ticket-divider {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin: 12px 0;
    }

    .ticket-meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .priority-dot-inline {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 6px;
    }

    /* COMMENTS */
    .comments-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
        border: 1px solid #e9ecef;
        margin-top: 20px;
    }

    .comments-header {
        padding: 20px 28px 0 28px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .comments-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #25262a;
        margin: 0;
    }

    .comments-count {
        font-size: 0.75rem;
        background-color: #f0f0f0;
        color: #6c757d;
        border-radius: 20px;
        padding: 2px 8px;
        font-weight: 600;
    }

    .comments-list {
        padding: 16px 28px;
    }

    .comment-bubble {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

    .comment-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background-color: #e8e8e8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: #6c757d;
        flex-shrink: 0;
    }

    .comment-content {
        flex: 1;
        background-color: #f8f9fa;
        border-radius: 0 10px 10px 10px;
        padding: 12px 16px;
    }

    .comment-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .comment-author {
        font-size: 0.82rem;
        font-weight: 600;
        color: #25262a;
    }

    .comment-time {
        font-size: 0.75rem;
        color: #9aa0a6;
    }

    .comment-text {
        font-size: 0.85rem;
        color: #495057;
        margin: 0;
        line-height: 1.5;
    }

    .comment-form-area {
        padding: 0 28px 24px 28px;
        border-top: 1px solid #f0f0f0;
        padding-top: 20px;
    }

        .comment-form-area textarea {
            border: 1px solid #e9ecef;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.875rem;
            resize: none;
            transition: border-color 0.2s ease;
        }

            .comment-form-area textarea:focus {
                border-color: #25262a;
                box-shadow: none;
            }

    .btn-comment {
        background-color: #25262a;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 20px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: background-color 0.2s ease;
    }

        .btn-comment:hover {
            background-color: #3a3b40;
            color: white;
        }

    .confirm-input:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
    }

    .status-badge {
        font-size: 0.75rem;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
</style>

<div class="ticket-wrapper">

    <!-- HEADER -->
    <div class="ticket-header">
        <div>
            <a asp-controller="Request" asp-action="Index" class="ticket-back">
                <i class="bi bi-arrow-left"></i> Volver a solicitudes
            </a>
            <p class="ticket-id">Solicitud #@Model.Id · @Model.Creation.ToString("dd/MM/yyyy HH:mm")</p>
            <h1 class="ticket-title">@Model.Title</h1>
        </div>
        <div class="d-flex gap-2 align-items-center mt-4">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Request" asp-action="Edit" asp-route-id="@Model.Id"
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>
                <button type="button" class="btn btn-sm btn-outline-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteModal">
                    <i class="bi bi-trash me-1"></i>Eliminar
                </button>
            }
        </div>
    </div>

    <div class="row g-4">

        <!-- COLUMNA PRINCIPAL -->
        <div class="col-md-8">

            <!-- DESCRIPCIÓN -->
            <div class="ticket-card">
                <div class="ticket-body">
                    <p class="ticket-section-label">Descripción</p>
                    <p style="font-size: 0.9rem; color: #495057; line-height: 1.7; margin: 0;">@Model.Description</p>
                </div>
            </div>

            <!-- COMENTARIOS -->
            <div class="comments-card">
                <div class="comments-header">
                    <span class="comments-title">Comentarios</span>
                    <span class="comments-count">@Model.Comments.Count</span>
                </div>

                <div class="comments-list">
                    @if (!Model.Comments.Any())
                    {
                        <p class="text-muted text-center py-3" style="font-size: 0.85rem;">No hay comentarios aún.</p>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                        {
                            var initials = string.Join("", comment.AuthorName.Split(' ').Take(2).Select(w => w[0]));
                            <div class="comment-bubble">
                                <div class="comment-avatar">@initials</div>
                                <div class="comment-content">
                                    <div class="comment-meta">
                                        <span class="comment-author">@comment.AuthorName</span>
                                        <span class="comment-time">
                                            @{
                                                var diff = DateTime.Now - comment.CreatedAt;
                                                string timeAgo;
                                                if (diff.TotalMinutes < 1)
                                                    timeAgo = "Hace un momento";
                                                else if (diff.TotalMinutes < 60)
                                                    timeAgo = $"Hace {(int)diff.TotalMinutes} min";
                                                else if (diff.TotalHours < 24)
                                                    timeAgo = $"Hace {(int)diff.TotalHours} h";
                                                else if (diff.TotalDays < 7)
                                                    timeAgo = $"Hace {(int)diff.TotalDays} días";
                                                else
                                                    timeAgo = comment.CreatedAt.ToString("dd/MM/yyyy");
                                            }
                                            @timeAgo
                                        </span>
                                    </div>
                                    <p class="comment-text">@comment.Text</p>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="comment-form-area">
                    <form asp-controller="Request" asp-action="AddComment" method="post">
                        <input type="hidden" name="requestId" value="@Model.Id" />
                        <textarea name="text" class="form-control mb-3" rows="3"
                                  placeholder="Escribe un comentario..."></textarea>
                        <button type="submit" class="btn-comment">Comentar</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- COLUMNA DERECHA: METADATA -->
        <div class="col-md-4">
            <div class="ticket-card">
                <div class="ticket-body">

                    <p class="ticket-section-label">Estado</p>
                    @{
                        var statusClass = Model.Status switch
                        {
                            ServiceFlow.Class.Models.Status.Open => "bg-primary",
                            ServiceFlow.Class.Models.Status.Assigned => "bg-info text-dark",
                            ServiceFlow.Class.Models.Status.InProgress => "bg-warning text-dark",
                            ServiceFlow.Class.Models.Status.OnHold => "bg-secondary",
                            ServiceFlow.Class.Models.Status.Resolved => "bg-success",
                            ServiceFlow.Class.Models.Status.Closed => "bg-dark",
                            ServiceFlow.Class.Models.Status.Cancelled => "bg-danger",
                            _ => "bg-secondary"
                        };
                        var statusText = Model.Status switch
                        {
                            ServiceFlow.Class.Models.Status.Open => "Abierta",
                            ServiceFlow.Class.Models.Status.Assigned => "Asignada",
                            ServiceFlow.Class.Models.Status.InProgress => "En Proceso",
                            ServiceFlow.Class.Models.Status.OnHold => "En Espera",
                            ServiceFlow.Class.Models.Status.Resolved => "Resuelta",
                            ServiceFlow.Class.Models.Status.Closed => "Cerrada",
                            ServiceFlow.Class.Models.Status.Cancelled => "Cancelada",
                            _ => "Desconocido"
                        };
                        var priorityColor = Model.Priority switch
                        {
                            ServiceFlow.Class.Models.Priority.Low => "#4CAF50",
                            ServiceFlow.Class.Models.Priority.Medium => "#FFC107",
                            ServiceFlow.Class.Models.Priority.High => "#FF9800",
                            ServiceFlow.Class.Models.Priority.Urgent => "#F44336",
                            _ => "#adb5bd"
                        };
                        var priorityText = Model.Priority switch
                        {
                            ServiceFlow.Class.Models.Priority.Low => "Baja",
                            ServiceFlow.Class.Models.Priority.Medium => "Media",
                            ServiceFlow.Class.Models.Priority.High => "Alta",
                            ServiceFlow.Class.Models.Priority.Urgent => "Urgente",
                            _ => "Desconocida"
                        };
                    }
                    <span class="badge @statusClass status-badge mb-2">@statusText</span>

                    <hr class="ticket-divider" />

                    <p class="ticket-section-label">Prioridad</p>
                    <p class="ticket-section-value mb-2">
                        <span class="priority-dot-inline" style="background-color: @priorityColor;"></span>
                        @priorityText
                    </p>

                    <hr class="ticket-divider" />

                    <p class="ticket-section-label">Solicitante</p>
                    <p class="ticket-section-value mb-2">@Model.RequesterName</p>

                    <hr class="ticket-divider" />

                    <p class="ticket-section-label">Asignado a</p>
                    <p class="ticket-section-value mb-2">@(Model.AssigneeName ?? "Sin asignar")</p>

                    <hr class="ticket-divider" />

                    <p class="ticket-section-label">Ubicación</p>
                    <p class="ticket-section-value mb-2">@Model.Location</p>

                    <hr class="ticket-divider" />

                    <p class="ticket-section-label">Fecha de registro</p>
                    <p class="ticket-section-value mb-0">@Model.Creation.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- MODAL ELIMINAR -->
@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>Eliminar Solicitud
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">Esta acción es <strong>irreversible</strong>. Se eliminará permanentemente la solicitud <strong>#@Model.Id — @Model.Title</strong> y todos sus comentarios.</p>
                    <hr />
                    <p class="small fw-semibold mb-2">Escribe <span class="text-danger fw-bold">CONFIRMAR</span> para continuar:</p>
                    <input type="text" id="confirmInput" class="form-control confirm-input" placeholder="CONFIRMAR" autocomplete="off" />
                    <p id="confirmError" class="text-danger small mt-1 d-none">Debes escribir CONFIRMAR exactamente.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form asp-controller="Request" asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" id="deleteBtn" class="btn btn-danger" disabled>
                            <i class="bi bi-trash me-1"></i>Eliminar definitivamente
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('confirmInput').addEventListener('input', function () {
            const val = this.value;
            const btn = document.getElementById('deleteBtn');
            const error = document.getElementById('confirmError');
            if (val === 'CONFIRMAR') {
                btn.disabled = false;
                error.classList.add('d-none');
            } else {
                btn.disabled = true;
                if (val.length > 0) error.classList.remove('d-none');
                else error.classList.add('d-none');
            }
        });
    </script>
}