@model ServiceFlow.Web.ViewModels.RequestDetailViewModel
@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<link rel="stylesheet" href="~/css/request-detail.css" asp-append-version="true" />

<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <a asp-controller="Request" asp-action="Index" class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>Volver a solicitudes
            </a>
            <h2 class="fw-bold mt-1 mb-0" style="color: #25262a;">@Model.Title</h2>
            <p class="text-muted small mb-0">Solicitud #@Model.Id · Registrada el @Model.Creation.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="d-flex gap-2">
            @{
                var statusClass = Model.Status switch
                {
                    ServiceFlow.Class.Models.Status.Open => "bg-primary",
                    ServiceFlow.Class.Models.Status.Assigned => "bg-info text-dark",
                    ServiceFlow.Class.Models.Status.InProgress => "bg-warning text-dark",
                    ServiceFlow.Class.Models.Status.OnHold => "bg-secondary",
                    ServiceFlow.Class.Models.Status.Resolved => "bg-success",
                    ServiceFlow.Class.Models.Status.Closed => "bg-dark",
                    ServiceFlow.Class.Models.Status.Cancelled => "bg-danger",
                    _ => "bg-secondary"
                };
                var statusText = Model.Status switch
                {
                    ServiceFlow.Class.Models.Status.Open => "Abierta",
                    ServiceFlow.Class.Models.Status.Assigned => "Asignada",
                    ServiceFlow.Class.Models.Status.InProgress => "En Proceso",
                    ServiceFlow.Class.Models.Status.OnHold => "En Espera",
                    ServiceFlow.Class.Models.Status.Resolved => "Resuelta",
                    ServiceFlow.Class.Models.Status.Closed => "Cerrada",
                    ServiceFlow.Class.Models.Status.Cancelled => "Cancelada",
                    _ => "Desconocido"
                };
                var priorityClass = Model.Priority switch
                {
                    ServiceFlow.Class.Models.Priority.Low => "bg-success",
                    ServiceFlow.Class.Models.Priority.Medium => "bg-warning text-dark",
                    ServiceFlow.Class.Models.Priority.High => "bg-orange",
                    ServiceFlow.Class.Models.Priority.Urgent => "bg-danger",
                    _ => "bg-secondary"
                };
                var priorityText = Model.Priority switch
                {
                    ServiceFlow.Class.Models.Priority.Low => "Baja",
                    ServiceFlow.Class.Models.Priority.Medium => "Media",
                    ServiceFlow.Class.Models.Priority.High => "Alta",
                    ServiceFlow.Class.Models.Priority.Urgent => "Urgente",
                    _ => "Desconocida"
                };
            }
            <span class="badge @priorityClass fs-6">@priorityText</span>
            <span class="badge @statusClass fs-6">@statusText</span>
        </div>
    </div>

    <div class="row g-4">

        <!-- COLUMNA IZQUIERDA: DETALLES -->
        <div class="col-md-8">

            <!-- DESCRIPCION -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #25262a;">Descripción</h5>
                    <p class="mb-0">@Model.Description</p>
                </div>
            </div>

            <!-- COMENTARIOS -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: #25262a;">
                        <i class="bi bi-chat-left-text me-2"></i>Comentarios
                        <span class="badge bg-secondary ms-2">@Model.Comments.Count</span>
                    </h5>

                    @if (!Model.Comments.Any())
                    {
                        <p class="text-muted text-center py-3">No hay comentarios aún.</p>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                        {
                            <div class="comment-item mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold">@comment.AuthorName</span>
                                    <span class="text-muted small">
                                        @{
                                            var diff = DateTime.Now - comment.CreatedAt;
                                            string timeAgo;
                                            if (diff.TotalMinutes < 1)
                                                timeAgo = "Hace un momento";
                                            else if (diff.TotalMinutes < 60)
                                                timeAgo = $"Hace {(int)diff.TotalMinutes} min";
                                            else if (diff.TotalHours < 24)
                                                timeAgo = $"Hace {(int)diff.TotalHours} h";
                                            else if (diff.TotalDays < 7)
                                                timeAgo = $"Hace {(int)diff.TotalDays} días";
                                            else
                                                timeAgo = comment.CreatedAt.ToString("dd/MM/yyyy");
                                        }
                                        @timeAgo
                                    </span>
                                </div>
                                <p class="mb-0 text-secondary">@comment.Text</p>
                            </div>
                            @if (comment != Model.Comments.OrderByDescending(c => c.CreatedAt).Last())
                            {
                                <hr class="my-3" />
                            }
                        }
                    }

                    <!-- FORMULARIO COMENTARIO -->
                    <hr class="mt-4" />
                    <h6 class="fw-bold mb-3">Agregar comentario</h6>
                    <form asp-controller="Request" asp-action="AddComment" method="post">
                        <input type="hidden" name="requestId" value="@Model.Id" />
                        <div class="mb-3">
                            <textarea name="text" class="form-control" rows="3" placeholder="Escribe tu comentario..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm px-4" style="background-color: #25262a; color: white;">
                            <i class="bi bi-send me-1"></i>Comentar
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- COLUMNA DERECHA: INFO -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: #25262a;">Información</h5>

                    <div class="mb-3">
                        <p class="text-muted small mb-1">Solicitante</p>
                        <p class="fw-semibold mb-0">@Model.RequesterName</p>
                    </div>
                    <hr />
                    <div class="mb-3">
                        <p class="text-muted small mb-1">Asignado a</p>
                        <p class="fw-semibold mb-0">@(Model.AssigneeName ?? "Sin asignar")</p>
                    </div>
                    <hr />
                    <div class="mb-3">
                        <p class="text-muted small mb-1">Ubicación</p>
                        <p class="fw-semibold mb-0">@Model.Location</p>
                    </div>
                    <hr />
                    <div class="mb-0">
                        <p class="text-muted small mb-1">Fecha de registro</p>
                        <p class="fw-semibold mb-0">@Model.Creation.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>